# GitLab
GITLAB_BASE_URL=https://gitlab.plunet.com
GITLAB_API_TOKEN=replace-me
GITLAB_PROJECT_PATHS=operations/dora-metrics

# Jira
JIRA_BASE_URL=https://plunet.atlassian.net
JIRA_USER_EMAIL=replace-me
JIRA_API_TOKEN=replace-me

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/dora_metrics

# Admin bootstrap
DORA_ADMIN_USERNAME=admin
DORA_ADMIN_PASSWORD=replace-me

# App-level encryption key for persisted secrets
CONFIG_ENCRYPTION_KEY=replace-with-32-byte-key
